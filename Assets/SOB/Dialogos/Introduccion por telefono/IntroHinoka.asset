  isQuestion: 1
  doSomethingAtEnd: 0
  dialoguesElements:
  - dialogues: Buenas noches Nozomi!
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: "Te quer\xEDa recordar de que le preguntes a las dem\xE1s si pueden
      ir ma\xF1ana"
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: "A ese sitio que tiene la distorsi\xF3n"
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: "Se que eres nueva en esto de la tecnolog\xEDa pero recuerda lo que
      te dije"
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: "Tienes que desbloquear tu tel\xE9fono"
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: Luego selecciona contactos, no te distraigas con los jueguitos que
      ya te conozco
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: Y solo selecciona a quien quieras llamar
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: "Yo de una vez te digo que yo s\xED puedo"
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  - dialogues: "Entonces, \xBFQuedamos?"
    girlName: 1
    girlImage: {fileID: 0}
    typingTime: 0.05
  questionText:
  - Quedamos, gracias hinoka
  - "\xBFMe puedes repetir como era para llamar?"
  - "\xBFQuedamos?"
